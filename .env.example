# Copy this file to .env and fill in your real key.
# .env is ignored by git.

LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_TIMEOUT_SECONDS=60
LLM_HTTP_RETRIES=2
LLM_REVIEW_DELAY_SECONDS=1

# Provider examples:
# Groq:    LLM_PROVIDER=groq,    LLM_MODEL=llama-3.3-70b-versatile, LLM_BASE_URL=https://api.groq.com/openai/v1
# NVIDIA:  LLM_PROVIDER=nvidia,  LLM_MODEL=meta/llama-3.1-70b-instruct, LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# Claude:  LLM_PROVIDER=claude,  LLM_MODEL=claude-sonnet-4-5, LLM_BASE_URL=https://api.anthropic.com/v1
